# YouTube API Configuration
# Get your API key from: https://console.cloud.google.com/
# Enable the YouTube Data API v3 in your Google Cloud project
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here

# Get your channel ID from: https://www.youtube.com/@slaqasalon
# Click on your profile → About → Channel ID (or use: https://www.youtube.com/@slaqasalon/about)
# Channel ID format: UCxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=your_channel_id_here
